{
  "__inputs": [
    {
      "name": "DS_PROMETHEUS",
      "label": "Prometheus",
      "description": "Prometheus data source scraping the ShadowDNS /metrics endpoint",
      "type": "datasource",
      "pluginId": "prometheus",
      "pluginName": "Prometheus"
    }
  ],
  "__requires": [
    {
      "type": "datasource",
      "id": "prometheus",
      "name": "Prometheus",
      "version": "1.0.0"
    },
    {
      "type": "grafana",
      "id": "grafana",
      "name": "Grafana",
      "version": "10.0.0"
    }
  ],
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": { "type": "grafana", "uid": "-- Grafana --" },
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "description": "Operational overview for ShadowDNS: traffic, latency, ECS/view selection, rate limiting, config/zones, Go runtime, and panics.",
  "editable": true,
  "graphTooltip": 1,
  "schemaVersion": 39,
  "tags": ["shadowdns", "dns"],
  "templating": {
    "list": [
      {
        "name": "DS_PROMETHEUS",
        "label": "Data source",
        "type": "datasource",
        "query": "prometheus",
        "current": {},
        "hide": 0,
        "refresh": 1,
        "regex": ""
      },
      {
        "name": "job",
        "label": "Job",
        "type": "query",
        "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
        "definition": "label_values(shadowdns_build_info, job)",
        "query": {
          "qryType": 1,
          "query": "label_values(shadowdns_build_info, job)",
          "refId": "StandardVariableQuery"
        },
        "includeAll": true,
        "multi": true,
        "refresh": 2,
        "sort": 1,
        "current": {}
      },
      {
        "name": "instance",
        "label": "Instance",
        "type": "query",
        "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
        "definition": "label_values(shadowdns_build_info{job=~\"$job\"}, instance)",
        "query": {
          "qryType": 1,
          "query": "label_values(shadowdns_build_info{job=~\"$job\"}, instance)",
          "refId": "StandardVariableQuery"
        },
        "includeAll": true,
        "multi": true,
        "refresh": 2,
        "sort": 1,
        "current": {}
      }
    ]
  },
  "time": { "from": "now-6h", "to": "now" },
  "timepicker": {},
  "timezone": "",
  "title": "ShadowDNS Overview",
  "uid": "shadowdns-overview",
  "version": 1,
  "panels": [
    {
      "type": "row",
      "title": "Overview",
      "collapsed": false,
      "id": 1,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 }
    },
    {
      "type": "stat",
      "title": "Build",
      "id": 2,
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 6, "w": 8, "x": 0, "y": 1 },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "/^(version|goversion)$/", "values": true },
        "textMode": "value",
        "colorMode": "none"
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "shadowdns_build_info{job=~\"$job\", instance=~\"$instance\"}",
          "instant": true,
          "format": "table"
        }
      ]
    },
    {
      "type": "stat",
      "title": "Process uptime",
      "id": 3,
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "description": "Derived from process_start_time_seconds (process collector; Linux).",
      "gridPos": { "h": 6, "w": 8, "x": 8, "y": 1 },
      "fieldConfig": { "defaults": { "unit": "s" } },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "value", "graphMode": "none" },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "time() - process_start_time_seconds{job=~\"$job\", instance=~\"$instance\"}"
        }
      ]
    },
    {
      "type": "stat",
      "title": "Total QPS",
      "id": 4,
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 6, "w": 8, "x": 16, "y": 1 },
      "fieldConfig": { "defaults": { "unit": "reqps" } },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "value" },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "sum(rate(shadowdns_dns_requests_total{job=~\"$job\", instance=~\"$instance\"}[$__rate_interval]))"
        }
      ]
    },
    {
      "type": "row",
      "title": "Traffic",
      "collapsed": false,
      "id": 10,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 7 }
    },
    {
      "type": "timeseries",
      "title": "QPS by protocol",
      "id": 11,
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 8 },
      "fieldConfig": { "defaults": { "unit": "reqps" } },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "sum by (proto) (rate(shadowdns_dns_requests_total{job=~\"$job\", instance=~\"$instance\"}[$__rate_interval]))",
          "legendFormat": "{{proto}}"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "QPS by address family",
      "id": 12,
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 8 },
      "fieldConfig": { "defaults": { "unit": "reqps" } },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "sum by (family) (rate(shadowdns_dns_requests_total{job=~\"$job\", instance=~\"$instance\"}[$__rate_interval]))",
          "legendFormat": "{{family}}"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "QPS by query type",
      "id": 13,
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 8 },
      "fieldConfig": { "defaults": { "unit": "reqps" } },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "sum by (type) (rate(shadowdns_dns_requests_total{job=~\"$job\", instance=~\"$instance\"}[$__rate_interval]))",
          "legendFormat": "{{type}}"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Responses by rcode",
      "id": 14,
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 16 },
      "fieldConfig": { "defaults": { "unit": "reqps" } },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "sum by (rcode) (rate(shadowdns_dns_responses_total{job=~\"$job\", instance=~\"$instance\"}[$__rate_interval]))",
          "legendFormat": "{{rcode}}"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Error response ratio (SERVFAIL / REFUSED / NXDOMAIN)",
      "id": 15,
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "description": "Ratios use 'or vector(0)' so a zero-traffic window renders 0 instead of an empty series.",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 16 },
      "fieldConfig": { "defaults": { "unit": "percentunit", "min": 0 } },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "(sum(rate(shadowdns_dns_responses_total{job=~\"$job\", instance=~\"$instance\", rcode=\"SERVFAIL\"}[$__rate_interval])) or vector(0)) / (sum(rate(shadowdns_dns_responses_total{job=~\"$job\", instance=~\"$instance\"}[$__rate_interval])) > 0)",
          "legendFormat": "SERVFAIL"
        },
        {
          "refId": "B",
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "(sum(rate(shadowdns_dns_responses_total{job=~\"$job\", instance=~\"$instance\", rcode=\"REFUSED\"}[$__rate_interval])) or vector(0)) / (sum(rate(shadowdns_dns_responses_total{job=~\"$job\", instance=~\"$instance\"}[$__rate_interval])) > 0)",
          "legendFormat": "REFUSED"
        },
        {
          "refId": "C",
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "(sum(rate(shadowdns_dns_responses_total{job=~\"$job\", instance=~\"$instance\", rcode=\"NXDOMAIN\"}[$__rate_interval])) or vector(0)) / (sum(rate(shadowdns_dns_responses_total{job=~\"$job\", instance=~\"$instance\"}[$__rate_interval])) > 0)",
          "legendFormat": "NXDOMAIN"
        }
      ]
    },
    {
      "type": "row",
      "title": "Latency",
      "collapsed": false,
      "id": 20,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 24 }
    },
    {
      "type": "timeseries",
      "title": "Request duration quantiles (all views)",
      "id": 21,
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 25 },
      "fieldConfig": { "defaults": { "unit": "s" } },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "histogram_quantile(0.50, sum by (le) (rate(shadowdns_dns_request_duration_seconds_bucket{job=~\"$job\", instance=~\"$instance\"}[$__rate_interval])))",
          "legendFormat": "p50"
        },
        {
          "refId": "B",
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "histogram_quantile(0.90, sum by (le) (rate(shadowdns_dns_request_duration_seconds_bucket{job=~\"$job\", instance=~\"$instance\"}[$__rate_interval])))",
          "legendFormat": "p90"
        },
        {
          "refId": "C",
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "histogram_quantile(0.99, sum by (le) (rate(shadowdns_dns_request_duration_seconds_bucket{job=~\"$job\", instance=~\"$instance\"}[$__rate_interval])))",
          "legendFormat": "p99"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "p99 request duration by view",
      "id": 22,
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 25 },
      "fieldConfig": { "defaults": { "unit": "s" } },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "histogram_quantile(0.99, sum by (le, view) (rate(shadowdns_dns_request_duration_seconds_bucket{job=~\"$job\", instance=~\"$instance\"}[$__rate_interval])))",
          "legendFormat": "{{view}}"
        }
      ]
    },
    {
      "type": "row",
      "title": "ECS & Views",
      "collapsed": false,
      "id": 30,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 33 }
    },
    {
      "type": "timeseries",
      "title": "View selection rate by view",
      "id": 31,
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 34 },
      "fieldConfig": { "defaults": { "unit": "reqps" } },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "sum by (view) (rate(shadowdns_dns_view_selected_total{job=~\"$job\", instance=~\"$instance\"}[$__rate_interval]))",
          "legendFormat": "{{view}}"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "ECS-geo participation ratio",
      "id": 32,
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "description": "Fraction of resolved views where an ECS-derived geo address was available to the matcher. It does NOT mean ECS decided the view (an ACL rule may have).",
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 34 },
      "fieldConfig": { "defaults": { "unit": "percentunit", "min": 0, "max": 1 } },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "(sum(rate(shadowdns_dns_view_selected_total{job=~\"$job\", instance=~\"$instance\", ecs_geo=\"true\"}[$__rate_interval])) or vector(0)) / (sum(rate(shadowdns_dns_view_selected_total{job=~\"$job\", instance=~\"$instance\"}[$__rate_interval])) > 0)",
          "legendFormat": "ecs_geo=true"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "ECS classification rate by status",
      "id": 33,
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "description": "Only populated when ECS handling is enabled (--ecs-enable) and queries carry an ECS option.",
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 34 },
      "fieldConfig": { "defaults": { "unit": "reqps" } },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "sum by (status) (rate(shadowdns_dns_ecs_queries_total{job=~\"$job\", instance=~\"$instance\"}[$__rate_interval]))",
          "legendFormat": "{{status}}"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "ECS carry rate (ECS queries / all requests)",
      "id": 34,
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 42 },
      "fieldConfig": { "defaults": { "unit": "percentunit", "min": 0 } },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "(sum(rate(shadowdns_dns_ecs_queries_total{job=~\"$job\", instance=~\"$instance\"}[$__rate_interval])) or vector(0)) / (sum(rate(shadowdns_dns_requests_total{job=~\"$job\", instance=~\"$instance\"}[$__rate_interval])) > 0)",
          "legendFormat": "ECS carry rate"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "ECS classification rate by family",
      "id": 35,
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 42 },
      "fieldConfig": { "defaults": { "unit": "reqps" } },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "sum by (family) (rate(shadowdns_dns_ecs_queries_total{job=~\"$job\", instance=~\"$instance\"}[$__rate_interval]))",
          "legendFormat": "{{family}}"
        }
      ]
    },
    {
      "type": "row",
      "title": "Rate Limiting",
      "collapsed": false,
      "id": 40,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 50 }
    },
    {
      "type": "timeseries",
      "title": "RRL decisions by category and action",
      "id": 41,
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 51 },
      "fieldConfig": { "defaults": { "unit": "reqps" } },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "sum by (category, action) (rate(shadowdns_dns_rate_limit_total{job=~\"$job\", instance=~\"$instance\"}[$__rate_interval]))",
          "legendFormat": "{{category}} / {{action}}"
        }
      ]
    },
    {
      "type": "row",
      "title": "Config & Zones",
      "collapsed": false,
      "id": 50,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 59 }
    },
    {
      "type": "timeseries",
      "title": "Reload attempts by result",
      "id": 51,
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 60 },
      "fieldConfig": { "defaults": { "unit": "short" } },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "sum by (result) (shadowdns_reload_total{job=~\"$job\", instance=~\"$instance\"})",
          "legendFormat": "{{result}}"
        }
      ]
    },
    {
      "type": "stat",
      "title": "Time since last successful reload",
      "id": 52,
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 60 },
      "fieldConfig": { "defaults": { "unit": "s" } },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "value", "graphMode": "none" },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "time() - shadowdns_config_last_reload_success_timestamp_seconds{job=~\"$job\", instance=~\"$instance\"}"
        }
      ]
    },
    {
      "type": "table",
      "title": "GeoIP databases",
      "id": 53,
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 60 },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "shadowdns_geoip_db_info{job=~\"$job\", instance=~\"$instance\"}",
          "instant": true,
          "format": "table"
        }
      ],
      "transformations": [
        {
          "id": "organize",
          "options": {
            "excludeByName": {
              "Time": true,
              "__name__": true,
              "job": true,
              "instance": true,
              "Value": true
            },
            "renameByName": { "database": "Database", "build_time": "Build time" }
          }
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Zones loaded by view (root)",
      "id": 54,
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 68 },
      "fieldConfig": { "defaults": { "unit": "short" } },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "shadowdns_zones_loaded{job=~\"$job\", instance=~\"$instance\"}",
          "legendFormat": "{{view}}"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Backup zones by view",
      "id": 55,
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 68 },
      "fieldConfig": { "defaults": { "unit": "short" } },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "shadowdns_zones_backup{job=~\"$job\", instance=~\"$instance\"}",
          "legendFormat": "{{view}}"
        }
      ]
    },
    {
      "type": "row",
      "title": "Runtime",
      "collapsed": false,
      "id": 60,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 76 }
    },
    {
      "type": "timeseries",
      "title": "Process CPU usage",
      "id": 61,
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "description": "process_* series are provided by the process collector and are Linux-only.",
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 77 },
      "fieldConfig": { "defaults": { "unit": "short" } },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "rate(process_cpu_seconds_total{job=~\"$job\", instance=~\"$instance\"}[$__rate_interval])",
          "legendFormat": "cpu cores"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Memory (RSS / Go heap)",
      "id": 62,
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 77 },
      "fieldConfig": { "defaults": { "unit": "bytes" } },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "process_resident_memory_bytes{job=~\"$job\", instance=~\"$instance\"}",
          "legendFormat": "RSS"
        },
        {
          "refId": "B",
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "go_memstats_alloc_bytes{job=~\"$job\", instance=~\"$instance\"}",
          "legendFormat": "Go heap alloc"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Goroutines",
      "id": 63,
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 77 },
      "fieldConfig": { "defaults": { "unit": "short" } },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "go_goroutines{job=~\"$job\", instance=~\"$instance\"}",
          "legendFormat": "goroutines"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Open file descriptors",
      "id": 64,
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "description": "process_* series are Linux-only.",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 85 },
      "fieldConfig": { "defaults": { "unit": "short" } },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "process_open_fds{job=~\"$job\", instance=~\"$instance\"}",
          "legendFormat": "open"
        },
        {
          "refId": "B",
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "process_max_fds{job=~\"$job\", instance=~\"$instance\"}",
          "legendFormat": "max"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "GC pause quantiles",
      "id": 65,
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 85 },
      "fieldConfig": { "defaults": { "unit": "s" } },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "go_gc_duration_seconds{job=~\"$job\", instance=~\"$instance\"}",
          "legendFormat": "quantile {{quantile}}"
        }
      ]
    },
    {
      "type": "row",
      "title": "Panics",
      "collapsed": false,
      "id": 70,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 93 }
    },
    {
      "type": "stat",
      "title": "Panics (total)",
      "id": 71,
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 6, "w": 8, "x": 0, "y": 94 },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": { "mode": "absolute", "steps": [ { "color": "green", "value": null }, { "color": "red", "value": 1 } ] }
        }
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background" },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "sum(shadowdns_panics_total{job=~\"$job\", instance=~\"$instance\"})"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Panic rate",
      "id": 72,
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 6, "w": 16, "x": 8, "y": 94 },
      "fieldConfig": { "defaults": { "unit": "short" } },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "sum(increase(shadowdns_panics_total{job=~\"$job\", instance=~\"$instance\"}[$__rate_interval]))",
          "legendFormat": "panics"
        }
      ]
    }
  ]
}
