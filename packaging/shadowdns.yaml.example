# shadowdns.yaml - Unified ShadowDNS Configuration
#
# This file combines the previous aliases.yaml with the new ephemeral TXT
# API settings into a single YAML document. It is referenced by the
# --config CLI flag and reloaded atomically on SIGHUP; if any section
# fails validation the running server keeps its previous state.

# ---- aliases -----------------------------------------------------------
#
# Maps each root domain to its backup (alias) domains. ShadowDNS serves
# backup domains by rewriting incoming queries to the root domain without
# loading separate zone data.
#
# Each value MUST be an object with:
#   members: <list of backup-domain strings, required, non-empty>
#   rewrite_rdata_labels: <bool, optional, default false>
#   collapse_cname_chain: <bool, optional, default false>
#
# rewrite_rdata_labels:
#   When true, RDATA name fields (CNAME target, NS, MX, SRV target, PTR,
#   SOA MNAME/RNAME) get an additional label-anywhere rewrite: every
#   contiguous root-label sequence inside the value is replaced with the
#   backup origin, not just the suffix. Use this when upstream zone files
#   use templated CNAMEs that point through the root origin as a middle
#   label (e.g. "host.<root>.cdn.example.net."). When false (default),
#   only the in-bailiwick suffix is rewritten — matching the conservative
#   DNS standard behavior.
#
# collapse_cname_chain:
#   When true, responses for this root zone and all of its backup members
#   consume in-zone CNAME chains instead of emitting them: a chain ending
#   at records of the queried type returns only those final records
#   (owner = query name, TTL = chain minimum); a chain leaving the zone
#   returns a single synthesized CNAME pointing at the first external
#   target; a chain ending without the queried type returns NODATA.
#   Intermediate chain names (internal load balancers, pools) never appear
#   in answers. Zone transfers (AXFR) are not affected. When false
#   (default), full chains are emitted exactly as BIND does.
#
# Rules:
#   - A backup domain may only appear once across all roots (duplicates rejected).
#   - A backup domain cannot equal its root (self-alias is rejected).
#   - A root entry's `members` list MUST be non-empty (empty or missing list rejected).
#   - To declare no aliases, omit the section or write `aliases: {}`.

aliases:
  # Default: rewrite_rdata_labels omitted → defaults to false.
  example.com:
    members:
      - backup-example.com
      - mirror-example.com

  # Explicit per-group flags: label-anywhere RDATA rewrite for
  # templated-CNAME (CDN-style) aliases, and CNAME chain collapsing to hide
  # in-zone intermediate names from responses.
  another-root.org:
    members:
      - backup-another.org
    rewrite_rdata_labels: true
    # collapse_cname_chain: true

  service.example.net:
    members:
      - shadow-service.net
    # rewrite_rdata_labels omitted → defaults to false

# ---- ephemeral_api -----------------------------------------------------
#
# Optional HTTP API for creating short-lived TXT records in memory
# (typically used for ACME DNS-01 challenges). When this section is
# omitted, no API server is started.
#
# Required fields:
#   listen — host:port to bind, e.g. "127.0.0.1:8053"
#   allow  — non-empty list of permitted source IPs or CIDR ranges
#
# Optional fields:
#   token — pre-shared bearer token; when set, every request must carry
#           "Authorization: Bearer <token>" and be from an allowed IP.
#           Omit to skip token validation entirely.

ephemeral_api:
  listen: "127.0.0.1:8053"
  allow:
    - "127.0.0.1"
    - "10.0.0.0/8"
  # token: "change-me-to-a-long-random-string"

# ---- doh ---------------------------------------------------------------
#
# Optional DNS-over-HTTPS (RFC 8484) server. When this section is omitted,
# no DoH server, ACME client, or HTTP-01 challenge listener is started.
#
# DoH reuses the authoritative query path and is NON-RECURSIVE: only
# zones hosted by ShadowDNS are answered; out-of-zone queries return
# REFUSED. This is not a general recursive resolver.
#
# Required fields:
#   listen — host:port the DoH HTTPS service binds, e.g. "203.0.113.10:443"
#   acme.directory_url — ACME directory URL of the issuing CA
#                        (absolute https:// URL)
#   acme.ip — the IP address the certificate is issued for
#             (RFC 8738 IP certificate)
#   acme.http01_listen — host:port the ACME HTTP-01 challenge responder
#                        binds; MUST be reachable from the public Internet
#                        as port 80
#
# The ACME account is registered with no contact email, so acme accepts
# no "email" field (RFC 8555 contact is optional; the short-lived
# auto-renewed certificate makes expiry notices moot).
#
# The certificate is obtained for the IP via ACME HTTP-01 using the
# Let's Encrypt short-lived profile (~6 days) and auto-renewed without a
# restart. Port 80 (http01_listen) must be public and serves only
# /.well-known/acme-challenge/; port 443 (listen) should be
# firewall-restricted to trusted source IPs.

# doh:
#   listen: "203.0.113.10:443"
#   acme:
#     directory_url: "https://acme-v02.api.letsencrypt.org/directory"
#     ip: "203.0.113.10"
#     http01_listen: "203.0.113.10:80"
