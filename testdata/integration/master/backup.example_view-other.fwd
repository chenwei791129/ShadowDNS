$TTL 300
@ IN SOA ns1.backup.example. hostmaster.backup.example. (
    1
    300
    120
    604800
    300
)

@   IN TXT   "google-site-verification=BACKUP_VIEW_OTHER_VERIFY_TOKEN"
@   IN MX    20 mx-backup.example.net.

; Pull in additional override records via a BIND-style quoted $include —
; exercises the include compatibility layer on a backup-classified zone.
$include "backup.example_overrides"
