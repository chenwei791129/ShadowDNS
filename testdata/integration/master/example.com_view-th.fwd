$TTL 300
@ IN SOA ns1.example.com. hostmaster.example.com. (
    2024010101  ; serial
    3600        ; refresh
    600         ; retry
    604800      ; expire
    300         ; minimum
)

@         IN NS    ns1.example.com.
@         IN NS    ns-external.example.net.
@         IN A     203.0.113.10
@         IN AAAA  2001:db8::10
@         IN MX    10 mx1.example.com.
@         IN TXT   "v=spf1 ip4:203.0.113.0/24 -all"

*         IN A     10.99.99.1
*.sub     IN CNAME target.example.com.
ent       IN TXT   "blocker"

ns1       IN A     203.0.113.1
mx1       IN A     203.0.113.20
www       IN A     203.0.113.30
www       IN AAAA  2001:db8::30
api       IN CNAME www.example.com.
cdn       IN CNAME d111111abcdef8.cloudfront.net.
mail      IN CNAME mx1.example.com.
_sip._tcp IN SRV   10 5 5060 sip.example.com.
sip       IN A     203.0.113.40

; CNAME chain for in-zone following tests
hop1      IN CNAME hop2.example.com.
hop2      IN CNAME hop3.example.com.
hop3      IN A     203.0.113.50
