$TTL 300
@ IN SOA ns1.example.com. hostmaster.example.com. (
    2024010101  ; serial — same as view-th, intentional
    3600
    600
    604800
    300
)

@         IN NS    ns1.example.com.
@         IN NS    ns-external.example.net.
@         IN A     198.51.100.10
@         IN AAAA  2001:db8:1::10
@         IN MX    10 mx1.example.com.
@         IN TXT   "v=spf1 ip4:198.51.100.0/24 -all"

*         IN A     10.99.99.1
*.sub     IN CNAME target.example.com.
ent       IN TXT   "blocker"

ns1       IN A     198.51.100.1
mx1       IN A     198.51.100.20
www       IN A     198.51.100.30
www       IN AAAA  2001:db8:1::30
api       IN CNAME www.example.com.
cdn       IN CNAME d222222abcdef8.cloudfront.net.
mail      IN CNAME mx1.example.com.
_sip._tcp IN SRV   10 5 5060 sip.example.com.
sip       IN A     198.51.100.40

; CNAME chain for in-zone following tests
hop1      IN CNAME hop2.example.com.
hop2      IN CNAME hop3.example.com.
hop3      IN A     198.51.100.50
