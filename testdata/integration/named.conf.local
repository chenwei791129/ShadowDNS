view "view-th" {
    match-clients {
        geoip country TH;
        geoip asnum "AS64500 Test ASN";
    };
    recursion no;

    zone "example.com" {
        type master;
        file "db.example.com-th";
    };

    zone "backup.example" {
        type master;
        file "db.backup.example-th";
    };
};

view "view-other" {
    match-clients {
        any;
    };
    recursion no;

    zone "example.com" {
        type master;
        file "db.example.com-other";
    };

    zone "backup.example" {
        type master;
        file "db.backup.example-other";
    };

    zone "include-test.example" {
        type master;
        file "db.include-test.example";
    };
};
