options {
    directory "TESTDATA_DIR_PLACEHOLDER";
    geoip-directory "TESTDATA_DIR_PLACEHOLDER/geoip";
    listen-on { any; };
    recursion no;
    minimal-responses yes;
    version none;
    hostname none;
    transfer-format many-answers;
    allow-transfer {
        192.0.2.10;
        192.0.2.11;
    };
    rate-limit {
        responses-per-second 10;
    };
};
